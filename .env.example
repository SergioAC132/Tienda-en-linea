# ─── Servidor ───────────────────────────────────────────────────────────────
PORT=3000

# ─── Base de Datos — PostgreSQL / Supabase ───────────────────────────────────
#
# OPCIÓN A: Supabase (desarrollo compartido del equipo — recomendado)
# Encuéntrala en: Supabase Dashboard → Project Settings → Database → Connection string → URI
#
DATABASE_URL=postgresql://postgres:[TU-PASSWORD]@db.[TU-PROYECTO].supabase.co:5432/postgres

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Clave secreta para firmar los tokens. Usa una cadena larga y aleatoria.
JWT_SECRET=cambia_esta_clave_por_una_segura_y_larga
JWT_EXPIRES_IN=7d

# ─── Multer / Imágenes ───────────────────────────────────────────────────────
# Carpeta local donde se guardan imágenes subidas (relativa a la raíz del proyecto)
UPLOAD_DIR=database/uploads
# Tamaño máximo por imagen en bytes (5 MB)
MAX_FILE_SIZE=5242880

# ─── Entorno ──────────────────────────────────────────────────────────────────
# Valores posibles: development | production
NODE_ENV=development
